{{!-- addTaskModal.hbs --}}
<div class="modal-overlay" id="add-task-modal" role="dialog" aria-modal="true" aria-labelledby="add-task-modal-title">
  <div class="modal-card">
    <div class="modal-card__header">
      <h3 class="modal-card__title" id="add-task-modal-title">Add a new task</h3>
      <button class="modal-card__close" id="close-add-task-modal" aria-label="Close add task modal">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <form id="add-task-form" novalidate>
      <div class="form-field">
        <input type="text" id="new-task-name" class="field-input" placeholder=" " />
        <label for="new-task-name" class="field-label">Task name</label>
        <span class="field-error" id="new-task-name-error"></span>
      </div>
      <div class="form-field">
        <input type="number" id="new-task-duration" class="field-input" placeholder=" " min="1" />
        <label for="new-task-duration" class="field-label">Duration (in minutes)</label>
        <span class="field-error" id="new-task-duration-error"></span>
      </div>
      <div class="form-field">
        <input type="time" id="new-task-time" class="field-input field-input--time" />
        <label for="new-task-time" class="field-label field-label--time">Time</label>
        <span class="field-error" id="new-task-time-error"></span>
      </div>
      <button type="submit" class="modal-submit-btn">Create Task</button>
    </form>
  </div>
</div>
