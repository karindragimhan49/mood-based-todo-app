<!-- ─────────────────────────────────────────────
     Partial: suggestedTask
     Used with: {{#each suggestions}}{{> suggestedTask}}{{/each}}
     Also rendered dynamically from JS.
──────────────────────────────────────────────── -->
<div class="suggestion-item">
  <div class="suggestion-item__body">

    <!-- Icon circle -->
    <div class="suggestion-item__icon suggestion-item__icon--{{iconType}}">
      <span>{{emoji}}</span>
    </div>

    <!-- Text info -->
    <div class="suggestion-item__info">
      <h3 class="suggestion-item__name">{{name}}</h3>
      <p  class="suggestion-item__duration">{{duration}} mins</p>
    </div>

    <!-- Meta + accept -->
    <div class="suggestion-item__meta">
      <span class="suggestion-item__based">Based on</span>
      <span class="suggestion-item__keyword">{{keyword}}</span>
      <!-- Accept button — JS attaches the click handler -->
      <button class="suggestion-item__check"
              data-action="accept-suggestion"
              data-title="{{name}}"
              data-duration="{{duration}}"
              aria-label="Add {{name}} to tasks">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </button>
    </div>

  </div>
</div>
