<!-- ═══════════════════════════════════════════════
     Partial: modals
     All application modals in one partial.
     Visibility controlled via the `hidden` attribute.
═══════════════════════════════════════════════ -->

<!-- ── 1. Login / Create Account Modal ─────────── -->
<div id="loginModal" class="modal-overlay" hidden role="dialog" aria-modal="true" aria-labelledby="loginTitle">
  <div class="modal-box">
    <div class="login-form__header">
      <span class="modal__icon">✦</span>
      <h2 id="loginTitle" class="modal__title">Welcome Back</h2>
      <p  class="modal__subtitle">Sign in or create your account to continue</p>
    </div>

    <form id="loginFormEl" class="modal__form" novalidate autocomplete="off">
      <div class="form-group">
        <label for="loginEmail" class="form-label">Email</label>
        <div class="login-form__input-wrap">
          <svg class="login-form__input-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
               viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <input id="loginEmail" name="email" type="email" class="form-input login-form__input"
                 placeholder="you@example.com" autocomplete="off" />
        </div>
        <span class="form-error" id="loginEmailErr"></span>
      </div>

      <div class="form-group">
        <label for="loginPassword" class="form-label">Password</label>
        <div class="login-form__input-wrap">
          <svg class="login-form__input-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
               viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
               stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <input id="loginPassword" name="password" type="password" class="form-input login-form__input"
                 placeholder="••••••••" autocomplete="off" />
        </div>
        <span class="form-error" id="loginPasswordErr"></span>
      </div>

      <div class="modal__footer">
        <button type="button" class="btn btn--ghost"  id="loginCancelBtn">Cancel</button>
        <button type="submit" class="btn btn--solid"  id="loginSubmitBtn">Sign In</button>
      </div>
    </form>
  </div>
</div>

<!-- ── 2. Edit Profile Modal ────────────────────── -->
<div id="editProfileModal" class="modal-overlay" hidden role="dialog" aria-modal="true" aria-labelledby="editProfileTitle">
  <div class="modal-box">
    <div class="login-form__header">
      <span class="modal__icon">👤</span>
      <h2 id="editProfileTitle" class="modal__title">Edit Profile</h2>
    </div>

    <form id="editProfileFormEl" class="modal__form" novalidate autocomplete="off">
      <div class="form-group">
        <label for="editUsername" class="form-label">Username</label>
        <input id="editUsername" name="username" type="text" class="form-input"
               placeholder="Your display name" />
        <span class="form-error" id="editUsernameErr"></span>
      </div>

      <div class="form-group">
        <label for="editEmail" class="form-label">Email</label>
        <input id="editEmail" name="email" type="email" class="form-input"
               placeholder="you@example.com" />
        <span class="form-error" id="editEmailErr"></span>
      </div>

      <div class="modal__footer modal__footer--space">
        <button type="button" class="btn btn--danger"  id="logoutBtn">Log Out</button>
        <div class="modal__footer-right">
          <button type="button" class="btn btn--ghost"  id="editProfileCancelBtn">Cancel</button>
          <button type="submit" class="btn btn--solid"  id="editProfileSaveBtn">Save</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- ── 3. Task Create / Edit Modal ──────────────── -->
<div id="taskModal" class="modal-overlay" hidden role="dialog" aria-modal="true" aria-labelledby="taskModalTitle">
  <div class="modal-box">
    <div class="creation-form-card__header">
      <button class="modal__close" data-modal="taskModal" aria-label="Close">✕</button>
      <h2 id="taskModalTitle" class="modal__title">Add New Task</h2>
    </div>

    <form id="taskFormEl" class="modal__form" novalidate autocomplete="off">
      <!-- Hidden id for edit mode -->
      <input type="hidden" id="taskEditId" name="editId" value="" />

      <div class="form-group">
        <label for="taskTitle" class="form-label">Task Title <span class="required">*</span></label>
        <input id="taskTitle" name="title" type="text" class="form-input"
               placeholder="e.g. Read a book" maxlength="80" />
        <span class="form-error" id="taskTitleErr"></span>
      </div>

      <div class="form-group">
        <label for="taskDescription" class="form-label">Description</label>
        <textarea id="taskDescription" name="description" class="form-input form-textarea"
                  placeholder="Optional description…" rows="3"></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="taskDuration" class="form-label">Duration (min) <span class="required">*</span></label>
          <input id="taskDuration" name="duration" type="number" class="form-input"
                 placeholder="30" min="1" max="1440" />
          <span class="form-error" id="taskDurationErr"></span>
        </div>

        <div class="form-group">
          <label for="taskDueDate" class="form-label">Due Date</label>
          <input id="taskDueDate" name="dueDate" type="date" class="form-input" />
        </div>
      </div>

      <div class="modal__footer">
        <button type="button" class="btn btn--ghost" data-modal="taskModal">Cancel</button>
        <button type="submit" class="btn btn--solid" id="taskSaveBtn">Add Task</button>
      </div>
    </form>
  </div>
</div>

<!-- ── 4. Mood Selector Modal ────────────────────── -->
<div id="moodModal" class="modal-overlay" hidden role="dialog" aria-modal="true" aria-labelledby="moodModalTitle">
  <div class="modal-box modal-box--sm">
    <div class="modal__header">
      <button class="modal__close" data-modal="moodModal" aria-label="Close">✕</button>
      <h2 id="moodModalTitle" class="modal__title">How are you feeling?</h2>
      <p class="modal__subtitle">Choose your current mood to personalize your tasks.</p>
    </div>

    <div id="moodOptions" class="mood-grid" role="group" aria-label="Mood options">
      <button class="mood-option" data-mood="Happy"     data-emoji="😊" aria-pressed="false">😊 Happy</button>
      <button class="mood-option" data-mood="Sad"       data-emoji="😔" aria-pressed="false">😔 Sad</button>
      <button class="mood-option" data-mood="Energized" data-emoji="⚡" aria-pressed="false">⚡ Energized</button>
      <button class="mood-option" data-mood="Tired"     data-emoji="😴" aria-pressed="false">😴 Tired</button>
      <button class="mood-option" data-mood="Focused"   data-emoji="🎯" aria-pressed="false">🎯 Focused</button>
      <button class="mood-option mood-option--active" data-mood="Neutral" data-emoji="😐" aria-pressed="true">😐 Neutral</button>
    </div>

    <div class="modal__footer modal__footer--center">
      <button id="moodConfirmBtn" class="btn btn--solid btn--full">Confirm Mood</button>
    </div>
  </div>
</div>

<!-- ── 5. Weather Modal ──────────────────────────── -->
<div id="weatherModal" class="modal-overlay" hidden role="dialog" aria-modal="true" aria-labelledby="weatherModalTitle">
  <div class="modal-box modal-box--sm weather-modal">
    <button class="modal__close" data-modal="weatherModal" aria-label="Close">✕</button>

    <!-- Loading state -->
    <div id="weatherLoading" class="weather-modal__loading">
      <div class="weather-modal__spinner"></div>
      <p>Fetching weather…</p>
    </div>

    <!-- Error state -->
    <div id="weatherError" class="weather-modal__error" hidden>
      <span class="weather-modal__error-icon">⚠️</span>
      <p id="weatherErrorMsg">Could not load weather data.</p>
      <button id="weatherRetryBtn" class="btn btn--outline btn--sm">Retry</button>
    </div>

    <!-- Data state -->
    <div id="weatherData" class="weather-modal__body" hidden>
      <div class="weather-modal__header">
        <h2 id="weatherModalTitle" class="weather-modal__city">—</h2>
        <p class="weather-modal__country" id="weatherCountry"></p>
      </div>

      <div class="weather-modal__main">
        <img id="weatherIcon" class="weather-modal__icon" src="" alt="Weather icon" width="80" height="80" />
        <div class="weather-modal__temp-wrap">
          <span id="weatherTemp" class="weather-modal__temp">—</span>
          <span class="weather-modal__unit">°C</span>
        </div>
        <p id="weatherDesc" class="weather-modal__desc">—</p>
      </div>

      <div class="weather-modal__details">
        <div class="weather-detail">
          <span class="weather-detail__label">Feels like</span>
          <span id="weatherFeels" class="weather-detail__value">—°C</span>
        </div>
        <div class="weather-detail">
          <span class="weather-detail__label">Humidity</span>
          <span id="weatherHumidity" class="weather-detail__value">—%</span>
        </div>
        <div class="weather-detail">
          <span class="weather-detail__label">Wind</span>
          <span id="weatherWind" class="weather-detail__value">— m/s</span>
        </div>
      </div>
    </div>
  </div>
</div>
