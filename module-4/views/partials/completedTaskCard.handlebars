<!-- ─────────────────────────────────────────────
     Partial: completedTaskCard
     Rendered in the Completed Tasks section.
──────────────────────────────────────────────── -->
<div class="task-card task-card--completed"
     data-id="{{id}}"
     data-action-area="card">

  <!-- Uncheck → move back to backlog -->
  <button class="task-card__check task-card__check--done"
          data-action="toggle"
          data-id="{{id}}"
          aria-label="Move back to backlog">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
  </button>

  <!-- Body -->
  <div class="task-card__body">
    <h3 class="task-card__title task-card__title--strike">{{title}}</h3>
    {{#if description}}
      <p class="task-card__desc task-card__desc--muted">{{description}}</p>
    {{/if}}
    <div class="task-card__meta">
      {{#if duration}}
        <span class="task-card__meta-item">{{duration}} min</span>
      {{/if}}
      {{#if dueDate}}
        <span class="task-card__meta-item task-card__due">{{dueDate}}</span>
      {{/if}}
      <span class="task-card__badge task-card__badge--done">Completed</span>
    </div>
  </div>

  <!-- Delete -->
  <button class="task-card__delete"
          data-action="delete"
          data-id="{{id}}"
          aria-label="Delete completed task">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="3 6 5 6 21 6"/>
      <path d="M19 6l-1 14H6L5 6"/>
      <path d="M10 11v6"/><path d="M14 11v6"/>
      <path d="M9 6V4h6v2"/>
    </svg>
  </button>
</div>
