<!-- ─────────────────────────────────────────────
     Partial: header
     Top navigation bar
──────────────────────────────────────────────── -->
<nav class="navbar">
  <div class="navbar__brand">
    <span class="navbar__logo">✦</span>
    <span class="navbar__app-name">MoodTask</span>
  </div>

  <div class="navbar__center">
    <!-- Mood pill -->
    <button id="moodBtn" class="navbar__mood-pill" aria-label="Set mood">
      <span id="moodEmoji">😐</span>
      <span id="moodText">Set Mood</span>
    </button>
  </div>

  <div class="navbar__actions">
    <!-- Weather button -->
    <button id="weatherBtn" class="navbar__icon-btn" aria-label="View weather" title="Weather">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
      </svg>
    </button>

    <!-- Notification bell (decorative) -->
    <button id="notifBtn" class="navbar__icon-btn" aria-label="Notifications" title="Notifications">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    </button>

    <!-- Profile / auth -->
    <button id="profileBtn" class="navbar__profile-btn" aria-label="Profile">
      <span class="navbar__avatar" id="navAvatar">?</span>
      <span class="navbar__username" id="navUsername">Sign In</span>
      <span class="navbar__role"    id="navRole"></span>
    </button>
  </div>
</nav>
