{{!-- =====================================================
     View: home
     Main Application Dashboard
====================================================== --}}

<!-- Navbar -->
{{> header}}

<!-- ── Main Content ────────────────────────────── -->
<main class="dashboard">
  <div class="dashboard__grid">

    <!-- ══════════════════════════════════════════
         LEFT COLUMN — Task Management
    ══════════════════════════════════════════ -->
    <section class="dashboard__col dashboard__col--left">

      <!-- Section header -->
      <div class="tasks-card">
        <div class="tasks-card__header">
          <div class="tasks-card__title-row">
            <h2 class="tasks-card__title">My Tasks</h2>
            <span id="taskCountLabel" class="tasks-card__count">0 tasks</span>
          </div>
          <div class="tasks-card__controls">
            <button id="completeAllBtn" class="btn btn--outline btn--sm">Complete All</button>
            <button id="showCompletedBtn" class="btn btn--ghost btn--sm">Show Completed</button>
            <button id="addTaskBtn" class="btn btn--solid btn--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              Add Task
            </button>
          </div>
        </div>

        <!-- Backlog task grid — rendered by tasksComponent.js -->
        <div id="taskGrid" class="task-grid" role="list" aria-label="Active tasks">
          <!-- JS will inject task cards here -->
        </div>

        <!-- Empty state -->
        <div id="emptyState" class="empty-state" hidden>
          <div class="empty-state__icon">📋</div>
          <h3 class="empty-state__title">No tasks yet</h3>
          <p  class="empty-state__sub">Hit <strong>Add Task</strong> to get started!</p>
        </div>
      </div>

      <!-- ── Completed Tasks Section ───────────── -->
      <div id="completedSection" class="tasks-card tasks-card--completed-section" hidden>
        <div class="tasks-card__header">
          <div class="tasks-card__title-row">
            <h2 class="tasks-card__title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              Completed Tasks
            </h2>
            <span id="completedCountLabel" class="tasks-card__count">0 done</span>
          </div>
          <button id="clearCompletedBtn" class="btn btn--ghost btn--sm btn--danger-ghost">
            Clear All
          </button>
        </div>

        <!-- Completed task grid — rendered by tasksComponent.js -->
        <div id="completedGrid" class="task-grid task-grid--completed" role="list" aria-label="Completed tasks">
          <!-- JS will inject completed task cards here -->
        </div>

        <div id="completedEmptyState" class="empty-state" hidden>
          <div class="empty-state__icon">🎉</div>
          <h3 class="empty-state__title">Nothing completed yet</h3>
          <p  class="empty-state__sub">Mark tasks done to see them here.</p>
        </div>
      </div>

    </section>

    <!-- ══════════════════════════════════════════
         RIGHT COLUMN — Suggested Tasks
    ══════════════════════════════════════════ -->
    <aside class="dashboard__col dashboard__col--right">
      <div class="suggested-card">
        <div class="suggested-card__header">
          <h2 class="suggested-card__title">Suggested Tasks</h2>
          <p  class="suggested-card__sub" id="suggestionsBadge">Based on your mood &amp; weather</p>
        </div>

        <!-- Suggestion list — rendered by suggestedTaskComponent.js -->
        <div id="suggestedList" class="suggested-card__list">
          <!-- JS will render suggestions here -->
        </div>
      </div>
    </aside>

  </div>
</main>

<!-- All Modals -->
{{> modals}}
